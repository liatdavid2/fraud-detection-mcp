# Required for AI investigation summaries
OPENAI_API_KEY=sk-your-key-here

# Model used by the investigation agent
OPENAI_MODEL=gpt-4.1-mini

# Real dataset path after running scripts/download_dataset.py
FRAUD_DATASET_PATH=data/processed/baf_base_sample.csv

# Trained model artifacts after running scripts/train_model.py
FRAUD_MODEL_PATH=models/fraud_model.joblib
FRAUD_MODEL_METADATA_PATH=models/fraud_model_metadata.json

# MLflow local tracking
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=fraud-detection-mcp

# API settings
APP_HOST=127.0.0.1
APP_PORT=8000
